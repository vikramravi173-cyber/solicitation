# Supabase — copy to .env.local and fill in from Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — server-side only (dev proxy reads this; never prefix with VITE_)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override Claude proxy URL (defaults to Supabase function or /api/claude in dev)
# VITE_CLAUDE_API_URL=https://your-project.supabase.co/functions/v1/claude
